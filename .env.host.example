# Copy to `.env.host` (gitignored). Loaded after `.env` and overrides variables for host-side runs.
# Use when running `go run ./cmd/api` on Windows/macOS/Linux while Postgres is in Docker with `5432:5432` published.
# Keep POSTGRES_* in `.env` in sync with the user, password, and database name below.

DATABASE_URL=postgres://taskflow:taskflow@localhost:5432/taskflow?sslmode=disable
