# =============================================================================
# TaskFlow — example environment (copy to `.env` for docker compose / local run)
# =============================================================================

# App ↔ Postgres (Compose DNS hostname `postgres` matches the service name)
DATABASE_URL=postgres://taskflow:taskflow@postgres:5432/taskflow?sslmode=disable
# For API on the host with Postgres in Docker: copy `.env.host.example` → `.env.host` (localhost URL).

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
SERVER_PORT=8080
# Must be >= 12 (TaskFlow requirement). Values below 12 are rejected at startup.
BCRYPT_COST=12
GIN_MODE=release

# Postgres container initialization (must match DATABASE_URL credentials)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow
